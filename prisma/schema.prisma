datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Profile {
  id                 String        @id @default(uuid())
  wid                Int           @unique @default(autoincrement())
  name               String        @default("Ansh Kumar")
  username           String        @unique @default("ansh")
  bio                String        @default("")
  avatar             String        @default("")
  verified           Boolean       @default(true)
  theme              String        @default("organic")
  bgStyle            String        @default("mesh")
  upiId              String?
  whatsappNumber     String?
  hobbies            String[]      @default([])
  currentlyExploring String?
  trialEndsAt        DateTime      @default(now())
  subscriptionStatus String        @default("trial")
  links              Link[]
  socialLinks        SocialLink[]
  cards              DigitalCard[]
  products           Product[]
  integrations       Integration[]
}

model Link {
  id        String   @id @default(uuid())
  title     String
  url       String
  subtitle  String?
  icon      String?
  active    Boolean  @default(true)
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model SocialLink {
  id        String   @id @default(uuid())
  platform  String
  url       String
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model DigitalCard {
  id             String   @id @default(uuid())
  cardName       String
  jobTitle       String
  company        String
  companyTagline String?
  phone          String
  email          String
  website        String
  theme          String
  active         Boolean  @default(true)
  qrLink         String?
  profileId      String
  profile        Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Product {
  id        String   @id @default(uuid())
  name      String
  price     String
  currency  String   @default("USD")
  imageUrl  String?
  linkUrl   String?
  active    Boolean  @default(true)
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Integration {
  id        String   @id @default(uuid())
  provider  String
  connected Boolean  @default(false)
  apiKey    String?
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
}
