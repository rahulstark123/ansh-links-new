datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Workspace {
  wid                Int            @id @default(autoincrement())
  userId             String?        @unique
  trialEndsAt        DateTime       @default(now())
  subscriptionStatus String         @default("trial")
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  profile            Profile?
  links              Link[]
  socialLinks        SocialLink[]
  cards              DigitalCard[]
  products           Product[]
  integrations       Integration[]
  trafficEvents      TrafficEvent[]
  customFields       CustomField[]
  supportTickets     SupportTicket[]
  subscriptions      Subscription[]
  transactions       Transaction[]
}

model Profile {
  id                 String         @id @default(uuid())
  wid                Int            @unique
  workspace          Workspace      @relation(fields: [wid], references: [wid], onDelete: Cascade)
  name               String         @default("Ansh Kumar")
  username           String         @unique @default("ansh")
  bio                String         @default("")
  avatar             String         @default("")
  verified           Boolean        @default(true)
  theme              String         @default("organic")
  bgStyle            String         @default("mesh")
  upiId              String?
  whatsappNumber     String?
  hobbies            String[]       @default([])
  currentlyExploring String?
  quickLinkIds       String[]       @default([])
  links              Link[]
  socialLinks        SocialLink[]
  cards              DigitalCard[]
  products           Product[]
  integrations       Integration[]
  trafficEvents      TrafficEvent[]
  customFields       CustomField[]
  supportTickets     SupportTicket[]
}

model Link {
  id        String    @id @default(uuid())
  wid       Int
  workspace Workspace @relation(fields: [wid], references: [wid], onDelete: Cascade)
  title     String
  url       String
  subtitle  String?
  icon      String?
  active    Boolean   @default(true)
  profileId String
  profile   Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([wid])
}

model SocialLink {
  id        String    @id @default(uuid())
  wid       Int
  workspace Workspace @relation(fields: [wid], references: [wid], onDelete: Cascade)
  platform  String
  url       String
  active    Boolean   @default(true)
  profileId String
  profile   Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([wid])
}

model DigitalCard {
  id             String    @id @default(uuid())
  wid            Int
  workspace      Workspace @relation(fields: [wid], references: [wid], onDelete: Cascade)
  cardName       String
  jobTitle       String
  company        String
  companyTagline String?
  companyLogo    String?
  phone          String
  email          String
  website        String
  theme          String
  active         Boolean   @default(true)
  qrLink         String?
  profileId      String
  profile        Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([wid])
}

model Product {
  id        String    @id @default(uuid())
  wid       Int
  workspace Workspace @relation(fields: [wid], references: [wid], onDelete: Cascade)
  name      String
  price     String
  currency  String    @default("USD")
  imageUrl  String?
  linkUrl   String?
  active    Boolean   @default(true)
  profileId String
  profile   Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([wid])
}

model Integration {
  id        String    @id @default(uuid())
  wid       Int
  workspace Workspace @relation(fields: [wid], references: [wid], onDelete: Cascade)
  provider  String
  connected Boolean   @default(false)
  apiKey    String?
  profileId String
  profile   Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([wid])
}

model TrafficEvent {
  id          String    @id @default(uuid())
  wid         Int
  workspace   Workspace @relation(fields: [wid], references: [wid], onDelete: Cascade)
  profileId   String
  profile     Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  action      String
  details     String?
  linkId      String?
  ipAddress   String?
  country     String?
  countryCode String?
  referrer    String?
  browser     String?
  device      String?
  userAgent   String?
  sessionId   String?
  createdAt   DateTime  @default(now())

  @@index([wid])
  @@index([wid, createdAt])
  @@index([wid, action])
  @@index([sessionId])
}

model CustomField {
  id        String    @id @default(uuid())
  wid       Int
  workspace Workspace @relation(fields: [wid], references: [wid], onDelete: Cascade)
  key       String
  value     String
  icon      String?   @default("Link2")
  active    Boolean   @default(true)
  profileId String
  profile   Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([wid])
}

model SupportTicket {
  id         String          @id @default(uuid())
  wid        Int
  workspace  Workspace       @relation(fields: [wid], references: [wid], onDelete: Cascade)
  profileId  String
  profile    Profile         @relation(fields: [profileId], references: [id], onDelete: Cascade)
  ticketRef  String          @unique
  subject    String
  category   String          @default("general")
  status     String          @default("open")
  priority   String          @default("medium")
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  messages   TicketMessage[]

  @@index([wid])
  @@index([wid, status])
}

model TicketMessage {
  id          String             @id @default(uuid())
  ticketId    String
  ticket      SupportTicket      @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorType  String             @default("user")
  authorName  String
  body        String
  createdAt   DateTime           @default(now())
  attachments TicketAttachment[]

  @@index([ticketId])
}

model TicketAttachment {
  id        String        @id @default(uuid())
  messageId String
  message   TicketMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  fileName  String
  fileUrl   String
  fileSize  Int
  mimeType  String
  createdAt DateTime      @default(now())

  @@index([messageId])
}

model Subscription {
  id                     String        @id @default(uuid())
  wid                    Int
  workspace              Workspace     @relation(fields: [wid], references: [wid], onDelete: Cascade)
  plan                   String
  status                 String        @default("active")
  currency               String
  amount                 Int
  billingInterval        String        @default("monthly")
  razorpaySubscriptionId String?
  currentPeriodStart     DateTime      @default(now())
  currentPeriodEnd       DateTime
  cancelledAt            DateTime?
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt
  transactions           Transaction[]

  @@index([wid])
  @@index([wid, status])
}

model Transaction {
  id                String        @id @default(uuid())
  wid               Int
  workspace         Workspace     @relation(fields: [wid], references: [wid], onDelete: Cascade)
  subscriptionId    String?
  subscription      Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  plan              String
  amount            Int
  currency          String
  status            String        @default("pending")
  provider          String        @default("razorpay")
  razorpayOrderId   String?
  razorpayPaymentId String?       @unique
  razorpaySignature String?
  receipt           String?
  countryCode       String?
  metadata          Json?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([wid])
  @@index([wid, status])
  @@index([razorpayOrderId])
}
